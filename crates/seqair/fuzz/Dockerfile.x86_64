FROM --platform=linux/amd64 rust:latest

RUN rustup default nightly && \
    rustup component add llvm-tools-preview && \
    cargo install cargo-fuzz

WORKDIR /seqair
COPY . .

# Pre-build fuzz targets
# Note: for fuzz_reader_indexed (tmpfile-based), run with --tmpfs /tmp for speed:
#   docker run --tmpfs /tmp --platform linux/amd64 seqair-fuzz-x86 "..."
RUN cd crates/seqair && cargo +nightly fuzz build

ENTRYPOINT ["bash", "-c"]
CMD ["cd crates/seqair && cargo +nightly fuzz list"]
